# Environment Variables for NLP Classifier App
# Copy this file to .env and fill in your values

# Flask API Configuration (if using api.py)
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Model Configuration
MODEL_PATH=./models
DATA_PATH=./data

# Optional: API Keys (if integrating external services in the future)
# OPENAI_API_KEY=your_key_here
# HUGGINGFACE_TOKEN=your_token_here

# Logging Configuration
LOG_LEVEL=INFO

# Note: This app currently doesn't require environment variables
# This file is provided for future extensibility
